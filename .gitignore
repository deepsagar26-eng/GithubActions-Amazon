bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio cache
.vs/

# ASP.NET scaffolding
ScaffoldingReadMe.txt

# Publish outputs
wwwroot/
*.publish.xml
*.pubxml
*.pubxml.user

# Logs
*.log

# -------------------------
# General
# -------------------------
# OS generated files
.DS_Store
Thumbs.db

# Node modules (if using npm for frontend assets)
node_modules/
