@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

@{
    ViewData["Title"] = "Mobile Store";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }

        h1 {
            text-align: center;
            color: #232f3e;
        }

        .store-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 25px;
            margin-top: 30px;
        }

        .mobile-card {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 20px;
            width: 220px;
            text-align: center;
            box-shadow: 0 3px 6px rgba(0,0,0,0.1);
            transition: transform 0.2s ease-in-out;
        }

            .mobile-card:hover {
                transform: scale(1.05);
                border-color: #ff9900;
            }

            .mobile-card i {
                font-size: 50px;
                color: #0073e6;
                margin-bottom: 15px;
            }

            .mobile-card h3 {
                font-size: 18px;
                margin: 10px 0;
                color: #333;
            }

        .price {
            font-weight: bold;
            color: #d32f2f;
            font-size: 16px;
        }

        .buy-btn {
            display: inline-block;
            margin-top: 12px;
            padding: 8px 15px;
            background-color: #ff9900;
            color: #fff;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
        }

            .buy-btn:hover {
                background-color: #e68a00;
            }
    </style>
</head>
<body>
    <h1>Welcome to Our Mobile Store</h1>

    <div class="store-container">
        <div class="mobile-card">
            <i class="fa-solid fa-mobile-screen-button"></i>
            <h3>Samsung Galaxy S23</h3>
            <p class="price">₹74,999</p>
            <a href="#" class="buy-btn">Buy Now</a>
        </div>

        <div class="mobile-card">
            <i class="fa-solid fa-mobile"></i>
            <h3>Apple iPhone 14</h3>
            <p class="price">₹79,900</p>
            <a href="#" class="buy-btn">Buy Now</a>
        </div>

        <div class="mobile-card">
            <i class="fa-solid fa-tablet-screen-button"></i>
            <h3>OnePlus 11</h3>
            <p class="price">₹56,999</p>
            <a href="#" class="buy-btn">Buy Now</a>
        </div>

        <div class="mobile-card">
            <i class="fa-solid fa-mobile-retro"></i>
            <h3>Redmi Note 12</h3>
            <p class="price">₹18,999</p>
            <a href="#" class="buy-btn">Buy Now</a>
        </div>
    </div>
</body>
</html>

